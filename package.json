{
  "name": "obsidian-quiddity",
  "version": "0.1.0",
  "description": "A tiny Markdown habit language that renders into an interactive Obsidian timeline.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "check": "npm run lint && npm run typecheck",
    "build": "npm run check && node esbuild.config.mjs production",
    "test": "node tests/parser-updater.test.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "habit-tracker",
    "markdown"
  ],
  "author": "Arta",
  "license": "MIT",
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-obsidianmd": "^0.2.8",
    "obsidian": "^1.8.7",
    "typescript": "^5.4.3",
    "typescript-eslint": "^8.59.1"
  }
}
